# AutoRG-Brain + MedSAM2 environment template
# Fill/adjust paths for your machine, then `source .env` or export manually.

AUTORG_USE_MEDSAM2=0
AUTORG_MEDSAM2_REPO=/home/jason/autorg/AutoRG-Brain/external/MedSAM2
AUTORG_MEDSAM2_CONFIG=configs/sam2.1_hiera_t512.yaml
AUTORG_MEDSAM2_CKPT=/home/jason/autorg/AutoRG-Brain/external/MedSAM2/checkpoints/MedSAM2_latest.pt
AUTORG_MEDSAM2_FREEZE=1
AUTORG_MEDSAM2_SLICE_CHUNK=4
AUTORG_MEDSAM2_INPUT_SIZE=256

# Optional alternative checkpoint from MedSAM2 repository (task-specific MedSAM2 model)
# AUTORG_MEDSAM2_CKPT=/home/jason/autorg/AutoRG-Brain/external/MedSAM2/checkpoints/MedSAM2_latest.pt
